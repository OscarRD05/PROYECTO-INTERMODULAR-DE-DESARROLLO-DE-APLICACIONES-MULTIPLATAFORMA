<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="App.View.ScannerPage"
    BackgroundColor="#f5f5f5"
    Title="Scanner NFC">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <Button
                Text="Salir"
                Clicked="OnLogoutClicked"
                HorizontalOptions="End"
                BackgroundColor="#dc3545"
                TextColor="White"
                WidthRequest="100" />

            <Label
                Text="Scanner NFC"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#222" />

            <Entry
                x:Name="BusquedaEntry"
                Placeholder="Escanea tarjeta o escribe nombre"
                BackgroundColor="White"
                TextColor="Black" />

            <Button
                Text="Buscar"
                Clicked="OnBuscarClicked"
                BackgroundColor="#2563eb"
                TextColor="White" />

            <Label
                x:Name="StatusLabel"
                Text="Esperando tarjeta..."
                HorizontalOptions="Center"
                TextColor="#666" />

            <Frame
                x:Name="AlumnoCard"
                IsVisible="False"
                CornerRadius="20"
                Padding="20"
                BackgroundColor="White"
                BorderColor="#dddddd">

                <VerticalStackLayout
                    Spacing="15"
                    HorizontalOptions="Center">

                    <Label
                        x:Name="NombreAlumnoLabel"
                        FontSize="24"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        TextColor="#111" />

                    <Label
                        x:Name="CursoAlumnoLabel"
                        FontSize="18"
                        HorizontalOptions="Center"
                        TextColor="#666" />

                    <Frame
                        x:Name="EstadoFrame"
                        CornerRadius="12"
                        Padding="10"
                        HorizontalOptions="Center">

                        <Label
                            x:Name="EstadoLabel"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalOptions="Center" />

                    </Frame>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>