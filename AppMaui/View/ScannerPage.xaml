<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="App.View.ScannerPage"
    BackgroundColor="#f5f5f5"
    Title="Scanner NFC">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="16">

            

            <Label
                Text="Scanner NFC"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#222" />

            <Entry
                x:Name="BusquedaEntry"
                Placeholder="Escanea tarjeta o escribe nombre"
                Completed="OnBusquedaCompleted"
                BackgroundColor="White"
                TextColor="Black" />

            <Button
                Text="Buscar"
                BackgroundColor="#007bff"
                TextColor="White"
                CornerRadius="12"
                Clicked="OnBusquedaClicked" />

            <Label
                x:Name="StatusLabel"
                Text="Esperando tarjeta..."
                HorizontalOptions="Center"
                TextColor="#666" />

            <ActivityIndicator
                x:Name="LoadingIndicator"
                IsRunning="False"
                IsVisible="False"
                Color="#007bff" />

            <Border
                x:Name="AlumnoCard"
                IsVisible="False"
                StrokeShape="RoundRectangle 20,20,20,20"
                StrokeThickness="1"
                Padding="20"
                BackgroundColor="White"
                Stroke="#dddddd">

                <VerticalStackLayout
                    Spacing="15"
                    HorizontalOptions="Center">

                    <Label
                        x:Name="NombreAlumnoLabel"
                        FontSize="24"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        TextColor="#111" />

                    <Label
                        x:Name="CursoAlumnoLabel"
                        FontSize="18"
                        HorizontalOptions="Center"
                        TextColor="#666" />

                    <Border
                        x:Name="EstadoFrame"
                        StrokeShape="RoundRectangle 12,12,12,12"
                        StrokeThickness="0"
                        Padding="10"
                        HorizontalOptions="Center">

                        <Label
                            x:Name="EstadoLabel"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalOptions="Center" />

                    </Border>

                    <Label
                        Text="Registrar asistencia"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        TextColor="#333"
                        Margin="0,10,0,5" />

                    <Button
                            x:Name="BtnEntrada"
                            Text="Entrada"
                            BackgroundColor="#28a745"
                            TextColor="White"
                            CornerRadius="12"
                            HorizontalOptions="Center"
                            Clicked="OnRegistrarEntrada" />

                        <Button
                            x:Name="BtnSalidaRecreo"
                            Text="Salida Recreo"
                            BackgroundColor="#17a2b8"
                            TextColor="White"
                            CornerRadius="12"
                            HorizontalOptions="Center"
                            IsVisible="False"
                            Clicked="OnRegistrarSalidaRecreo" />

                        <Button
                            x:Name="BtnSalidaAnticipada"
                            Text="Salida Anticipada"
                            BackgroundColor="#dc3545"
                            TextColor="White"
                            CornerRadius="12"
                            HorizontalOptions="Center"
                            Clicked="OnRegistrarSalidaAnticipada" />

                    <Label
                        x:Name="RegistroStatusLabel"
                        FontSize="14"
                        HorizontalOptions="Center"
                        TextColor="#28a745"
                        IsVisible="False" />

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>