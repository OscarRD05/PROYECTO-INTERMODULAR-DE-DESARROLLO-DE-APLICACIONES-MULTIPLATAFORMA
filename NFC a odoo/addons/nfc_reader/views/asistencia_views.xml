<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== REGISTROS ASISTENCIA ===================== -->
    <record id="view_nfc_asistencia_list" model="ir.ui.view">
        <field name="name">nfc.registro_asistencia.list</field>
        <field name="model">nfc.registro_asistencia</field>
        <field name="arch" type="xml">
            <list>
                <field name="fecha_hora"/>
                <field name="alumno_id"/>
                <field name="tipo"/>
                <field name="justificado"/>
                <field name="motivo"/>
                <field name="profesor_id"/>
            </list>
        </field>
    </record>

    <record id="view_nfc_asistencia_form" model="ir.ui.view">
        <field name="name">nfc.registro_asistencia.form</field>
        <field name="model">nfc.registro_asistencia</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="alumno_id"/>
                        <field name="fecha_hora"/>
                        <field name="tipo"/>
                        <field name="justificado"/>
                        <field name="motivo"/>
                        <field name="profesor_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nfc_asistencia" model="ir.actions.act_window">
        <field name="name">Registros de Asistencia</field>
        <field name="res_model">nfc.registro_asistencia</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_nfc_asistencia" name="Asistencia" parent="menu_nfc_root" action="action_nfc_asistencia" sequence="40"/>
</odoo>